rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'userId', 'layers', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.userId == request.auth.uid &&
             data.layers is list && data.layers.size() < 50;
    }

    // Projects Collection
    match /projects/{projectId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidProject(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
