{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A photo editing project containing multiple layers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "layers": {
          "type": "array",
          "items": { "$ref": "Layer" }
        },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "thumbnail": { "type": "string" }
      },
      "required": ["id", "name", "userId", "layers", "createdAt", "updatedAt"]
    },
    "Layer": {
      "title": "Layer",
      "description": "A single layer in a project (image, text, or shape)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "text", "shape"] },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "rotation": { "type": "number" },
        "opacity": { "type": "number" },
        "visible": { "type": "boolean" },
        "src": { "type": "string" },
        "content": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User photo editing projects"
    }
  }
}
